<!DOCTYPE html>
<html>

<head>
  <title>Green Policy | Login Portal</title>

  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Professional Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <!-- Formal UI CSS -->
  <link rel="stylesheet" href="/css/formal.css">

  <!-- Theme Toggle Script (Run early to prevent flash) -->
  <script src="/js/theme.js"></script>

  <style>
    body {
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
    }

    .theme-toggle-btn {
      position: absolute;
      top: 20px;
      right: 20px;
      background: transparent;
      border: 1px solid var(--border-color);
      color: var(--text-main);
      border-radius: 50%;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .theme-toggle-btn:hover {
      background: var(--border-color);
    }

    .login-wrapper {
      width: 100%;
      max-width: 400px;
      padding: 15px;
    }

    .formal-card {
      padding: 35px;
    }

    .brand-header {
      font-size: 24px;
      font-weight: 600;
      text-align: center;
      margin-bottom: 5px;
      color: var(--text-main);
    }

    .brand-sub {
      text-align: center;
      font-size: 14px;
    }
  </style>

</head>


<body>

  <!-- Theme Toggle Button -->
  <button class="theme-toggle-btn shadow-sm" onclick="toggleFormalTheme()" title="Toggle Dark/Light Mode">
    <i id="theme-icon" class="bi bi-moon-stars"></i>
  </button>

  <div class="login-wrapper">
    <div class="card formal-card">

      <div class="brand-header">
        <i class="bi bi-shield-lock text-primary"></i> Green Policy
      </div>

      <p class="brand-sub text-muted mb-4">
        Secure Administrator & Staff Portal
      </p>


      <form action="/login" method="POST">


        <!-- Email -->
        <div class="mb-3">

          <label class="form-label">Email Address</label>

          <input type="email" name="email" class="form-control" placeholder="name@institution.edu" required>

        </div>


        <!-- Password -->
        <div class="mb-4">

          <label class="form-label">Password</label>

          <input type="password" name="password" class="form-control" placeholder="Enter password" required>

        </div>


        <!-- Button -->
        <button class="btn btn-primary w-100 py-2">
          Sign In
        </button>

      </form>


      <hr class="text-muted mt-4 mb-3" style="opacity: 0.2;">


      <p class="text-center text-muted mt-2" style="font-size: 12px;">
        &copy; <%= new Date().getFullYear() %> Academic Green Policy Management System
      </p>

    </div>
  </div>

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

</body>

</html>