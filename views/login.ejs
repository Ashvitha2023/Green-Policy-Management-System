<!DOCTYPE html>
<html>
<head>
<title>Green Policy Login</title>

<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
  background: linear-gradient(to right, #43cea2, #185a9d);
  height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  font-family: Arial, sans-serif;
}

.login-card{
  background:white;
  padding:30px;
  border-radius:15px;
  width:100%;
  max-width:400px;
  box-shadow:0 0 15px rgba(0,0,0,0.2);
}

.logo{
  font-size:26px;
  font-weight:bold;
  text-align:center;
  color:#198754;
}

.sub{
  text-align:center;
  color:gray;
  font-size:14px;
}

</style>

</head>


<body>

<div class="login-card">

  <div class="logo">
    🌱 Green Policy System
  </div>

  <p class="sub mb-4">
    Login to Continue
  </p>


  <form action="/login" method="POST">


    <!-- Email -->
    <div class="mb-3">

      <label class="form-label">Email</label>

      <input
        type="email"
        name="email"
        class="form-control"
        placeholder="Enter email"
        required>

    </div>


    <!-- Password -->
    <div class="mb-3">

      <label class="form-label">Password</label>

      <input
        type="password"
        name="password"
        class="form-control"
        placeholder="Enter password"
        required>

    </div>


    <!-- Button -->
    <button class="btn btn-success w-100">
      Login
    </button>

  </form>


  <hr>


  <p class="text-center text-muted mt-2">
    Academic Green Policy Management System
  </p>

</div>

</body>
</html>
