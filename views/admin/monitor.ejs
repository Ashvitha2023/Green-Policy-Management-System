<!DOCTYPE html>
<html>
<head>
  <title>Monitor Policies</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-success px-3">
  <span class="navbar-brand">📊 Policy Monitor</span>

  <div>
    <a href="/admin" class="btn btn-outline-light me-2">Dashboard</a>
    <a href="/logout" class="btn btn-outline-light">Logout</a>
  </div>
</nav>


<div class="container mt-4">

<h4 class="mb-3">All Assigned Policies</h4>

<table class="table table-bordered table-hover">

<thead class="table-dark">
<tr>
  <th>Policy</th>
  <th>Department</th>
  <th>Staff</th>
  <th>Status</th>
  <th>Students</th>
  <th>Proof</th>
</tr>
</thead>

<tbody>

<% if(reports.length === 0){ %>

<tr>
  <td colspan="6" class="text-center">
    No records found
  </td>
</tr>

<% } %>


<% reports.forEach(r => { %>

<tr>

<td><%= r.policy %></td>
<td><%= r.department %></td>
<td><%= r.staff %></td>

<td>
  <%= r.status %>
</td>

<td><%= r.students %></td>

<td>

<% if(r.file_path){ %>

  <a href="/<%= r.file_path %>" target="_blank">
    View
  </a>

<% } else { %>

  --

<% } %>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>
