<!DOCTYPE html>
<html>
<head>
  <title>Monitor Policies</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-success px-3">
  <span class="navbar-brand">📊 Policy Monitor</span>

  <div>
    <a href="/admin" class="btn btn-outline-light me-2">Dashboard</a>
    <a href="/logout" class="btn btn-outline-light">Logout</a>
  </div>
</nav>


<div class="container mt-4">

<h4 class="mb-3">All Assigned Policies</h4>

<table class="table table-bordered table-hover align-middle">

<thead class="table-dark">
<tr>
  <th>Policy</th>
  <th>Department</th>
  <th>Staff</th>
  <th>Status</th>
  <th>Students</th>
  <th>Proof</th>
  <th>Action</th> <!-- ✅ NEW -->
</tr>
</thead>

<tbody>

<% if(reports.length === 0){ %>

<tr>
  <td colspan="7" class="text-center">
    No records found
  </td>
</tr>

<% } %>


<% reports.forEach(r => { %>

<tr>

<td><%= r.policy %></td>
<td><%= r.department %></td>
<td><%= r.staff %></td>

<td>

<% if(r.status && r.status.trim() === 'completed'){ %>
  <span class="badge bg-success">Completed</span>

<% } else if(r.status && r.status.trim() === 'pending_verification'){ %>
  <span class="badge bg-warning text-dark">Verify</span>

<% } else { %>
  <span class="badge bg-danger">Pending</span>
<% } %>

</td>

<td><%= r.students %></td>


<td>

<% if(r.file_path){ %>

  <a href="/<%= r.file_path %>" target="_blank"
     class="btn btn-sm btn-info">
    View
  </a>

<% } else { %>

  --

<% } %>

</td>


<!-- ✅ ACTION BUTTONS -->
<td>

<% if(r.status && r.status.trim() === 'pending_verification'){ %>

<form action="/admin/verify" method="POST" class="d-flex gap-1">

  <input type="hidden" name="id" value="<%= r.spid %>">

  <button name="action" value="approve"
          class="btn btn-success btn-sm">
    Approve
  </button>

  <button name="action" value="reject"
          class="btn btn-danger btn-sm">
    Reject
  </button>

</form>

<% } else { %>

  --

<% } %>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>
