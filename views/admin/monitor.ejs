<!DOCTYPE html>
<html>

<head>
  <title>Green Policy | Monitor</title>

  <meta name="viewport" content="width=device-width, initial-scale=1">
  <!-- Professional Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <!-- Premium UI CSS -->
  <link rel="stylesheet" href="/css/premium.css">

  <!-- Theme Toggle Script -->
  <script src="/js/theme.js"></script>
</head>

<body>

  <nav class="navbar px-4 py-2">
    <span class="navbar-brand mb-0 h1 d-flex align-items-center gap-2">
      <i class="bi bi-shield-lock"></i> Green Policy
      <span class="text-muted fs-6 ms-2 pb-1 border-start border-secondary ps-3">Policy Monitoring Center</span>
    </span>

    <div class="d-flex align-items-center gap-3">
      <button class="btn btn-outline-light btn-sm rounded-circle d-flex align-items-center justify-content-center"
        style="width: 32px; height: 32px;" onclick="toggleFormalTheme()" title="Toggle Dark/Light Mode">
        <i id="theme-icon" class="bi bi-moon-stars"></i>
      </button>

      <div>
        <a href="/admin" class="btn btn-outline-light btn-sm me-2 px-3">
          <i class="bi bi-grid-1x2"></i> Dashboard
        </a>
        <a href="/logout" class="btn btn-outline-danger btn-sm px-3">
          <i class="bi bi-box-arrow-right"></i> Logout
        </a>
      </div>
    </div>
  </nav>


  <div class="container-fluid py-4 px-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
      <div>
        <h3 class="mb-1 text-primary fw-semibold">Active Policies Overview</h3>
        <p class="text-muted small mb-0">Track policy status, adherence metrics, and documentation across departments.
        </p>
      </div>
    </div>

    <% if(typeof warning !== 'undefined' && warning) { %>
      <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Notice:</strong> <%= warning %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>


    <div class="card glass-card">
      <div class="card-body p-0 border-0">

        <div class="table-responsive m-0">
          <table class="table table-hover align-middle mb-0">

            <thead>
              <tr>
                <th class="ps-4">Policy Identifier</th>
                <th>Department</th>
                <th>Assigned Staff</th>
                <th>Current Status</th>
                <th class="text-center">Student Impact</th>
                <th class="text-center">Documentation</th>
                <th class="text-center pe-4">Required Actions</th>
              </tr>
            </thead>

            <tbody>

              <% if(reports.length===0){ %>

                <tr>
                  <td colspan="7" class="text-center text-muted py-5">
                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                    No active policies or reports found in the system.
                  </td>
                </tr>

                <% } %>


                  <% reports.forEach(r=> { %>

                    <tr>

                      <td class="ps-4 fw-medium text-dark">
                        <%= r.policy %>
                      </td>

                      <td>
                        <%= r.department %>
                      </td>

                      <td>
                        <div class="d-flex align-items-center">
                          <div
                            class="bg-light text-primary rounded-circle d-flex align-items-center justify-content-center me-2"
                            style="width: 28px; height: 28px;">
                            <i class="bi bi-person-fill small"></i>
                          </div>
                          <div>
                            <div class="fw-medium"><%= r.staff %></div>
                            <div class="text-muted" style="font-size: 0.75rem;"><%= r.staff_active_count %> active policies</div>
                          </div>
                        </div>
                      </td>

                      <td>

                        <% if(r.status && r.status.trim()==='completed' ){ %>
                          <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i> Completed</span>

                          <% } else if(r.status && r.status.trim()==='pending_verification' ){ %>
                            <span class="badge bg-warning"><i class="bi bi-hourglass-split me-1"></i> Review
                              Required</span>

                            <% } else { %>
                              <span class="badge bg-secondary"><i class="bi bi-arrow-repeat me-1"></i> In
                                Progress</span>
                              <% } %>

                      </td>

                      <td class="text-center">
                        <span class="badge bg-light text-dark border mb-1 d-inline-block">
                          <%= r.students %> Enrolled
                        </span>
                        <% if(r.student_details) { %>
                          <div class="dropdown mt-1">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle py-0 px-2" style="font-size: 0.75rem;" type="button" data-bs-toggle="dropdown">
                              Details
                            </button>
                            <ul class="dropdown-menu shadow-sm" style="font-size: 0.85rem;">
                              <% r.student_details.split('|').forEach(detail => { %>
                                <li><span class="dropdown-item py-1"><i class="bi bi-person text-muted me-1"></i><%= detail %></span></li>
                              <% }) %>
                            </ul>
                          </div>
                        <% } %>
                      </td>


                      <td class="text-center">

                        <% if(r.file_path){ %>

                          <a href="/<%= r.file_path %>" target="_blank"
                            class="btn btn-sm btn-outline-primary shadow-sm px-3 rounded-pill">
                            <i class="bi bi-paperclip"></i> View File
                          </a>

                          <% } else { %>

                            <span class="text-muted small fst-italic">Pending Upload</span>

                            <% } %>

                      </td>


                      <td class="text-center pe-4">

                        <% if(r.status && r.status.trim()==='pending_verification' ){ %>

                          <form action="/admin/verify" method="POST" class="d-flex gap-2 justify-content-center">

                            <input type="hidden" name="id" value="<%= r.spid %>">

                            <button name="action" value="approve" class="btn btn-success btn-sm px-3"
                              title="Approve Report">
                              Approve
                            </button>

                            <button type="button" class="btn btn-outline-danger btn-sm px-3" data-bs-toggle="modal" data-bs-target="#rejectModal<%= r.spid %>"
                              title="Reject Report">
                              Reject
                            </button>

                          </form>



                          <% } else { %>

                            <span class="text-muted small">—</span>

                            <% } %>

                      </td>

                    </tr>

                    <% }) %>

            </tbody>

          </table>
        </div>

      </div>
    </div>

  </div>

  <% reports.forEach(r => { %>
    <% if(r.status && r.status.trim()==='pending_verification' ){ %>
      <!-- Reject Modal -->
      <div class="modal fade" id="rejectModal<%= r.spid %>" tabindex="-1">
        <div class="modal-dialog">
          <form action="/admin/verify" method="POST" class="modal-content text-dark">
            <div class="modal-header">
              <h5 class="modal-title">Reject Submission</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <input type="hidden" name="id" value="<%= r.spid %>">
              <input type="hidden" name="action" value="reject">
              <div class="mb-3">
                <label class="form-label fw-medium">Reason for Rejection</label>
                <textarea name="rejection_reason" class="form-control" rows="3" required placeholder="Outline what is missing or needs correction..."></textarea>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-danger">Confirm Rejection</button>
            </div>
          </form>
        </div>
      </div>
    <% } %>
  <% }) %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>