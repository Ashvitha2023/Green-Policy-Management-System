      <a href="/admin/create-policy" class="btn btn-success mt-2">
        Go
      </a>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card shadow text-center p-4">
      <i class="bi bi-bar-chart fs-1 text-primary"></i>
      <h5 class="mt-2">Monitor Policies</h5>

      <a href="/admin/monitor" class="btn btn-primary mt-2">
        Go
      </a>
    </div>
  </div>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

