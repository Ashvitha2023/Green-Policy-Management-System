<!DOCTYPE html>
<html>
<head>
<title>Student Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<!-- Navbar -->
<nav class="navbar navbar-dark bg-success px-3">
  <span class="navbar-brand">🎓 Student Panel</span>

  <a href="/logout" class="btn btn-outline-light">
    Logout
  </a>
</nav>


<div class="container mt-4">

<h3 class="mb-4">My Assigned Policies</h3>

<div class="row g-4">

<% if(policies.length === 0){ %>

<div class="col-12 text-center">
  <p>No policy assigned yet.</p>
</div>

<% } %>


<% policies.forEach(p => { %>

<div class="col-md-4">

<div class="card shadow h-100">

  <div class="card-body">

    <h5 class="card-title">
      <%= p.title %>
    </h5>

    <p class="text-muted">
      <%= p.description %>
    </p>

    <p><b>Department:</b> <%= p.department %></p>
    <p><b>Staff:</b> <%= p.staff %></p>

    <p>
      <b>Status:</b>

      <% if(p.status === 'completed'){ %>
        <span class="badge bg-success">Completed</span>
      <% } else { %>
        <span class="badge bg-warning text-dark">In Progress</span>
      <% } %>
    </p>

  </div>

</div>

</div>

<% }) %>

</div>

</div>

</body>
</html>
