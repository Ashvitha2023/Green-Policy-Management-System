<!DOCTYPE html>
<html>

<head>
  <title>Green Policy | Policy Details</title>

  <meta name="viewport" content="width=device-width, initial-scale=1">
  <!-- Professional Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <!-- Premium UI CSS -->
  <link rel="stylesheet" href="/css/premium.css">

  <!-- Theme Toggle Script -->
  <script src="/js/theme.js"></script>

</head>

<body>


  <nav class="navbar px-4 py-2">
    <span class="navbar-brand mb-0 h1 d-flex align-items-center gap-2">
      <i class="bi bi-shield-lock"></i> Green Policy
      <span class="text-muted fs-6 ms-2 pb-1 border-start border-secondary ps-3">Policy Details</span>
    </span>

    <div class="d-flex align-items-center gap-3">
      <button class="btn btn-outline-light btn-sm rounded-circle d-flex align-items-center justify-content-center"
        style="width: 32px; height: 32px;" onclick="toggleFormalTheme()" title="Toggle Dark/Light Mode">
        <i id="theme-icon" class="bi bi-moon-stars"></i>
      </button>

      <a href="/staff" class="btn btn-outline-light btn-sm px-3">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
      </a>
    </div>
  </nav>


  <div class="container py-4">

    <div class="row justify-content-center">
      <div class="col-lg-8">

        <div class="card glass-card p-4">

          <div class="d-flex justify-content-between align-items-start mb-4 pb-3 border-bottom">
            <div>
              <h3 class="mb-1 text-primary fw-semibold">
                <%= policy.title %>
              </h3>
              <p class="text-muted small mb-0">Policy Identifier: <%= spid %>
              </p>
              <% if(policy.deadline) { %>
                <p class="text-danger small fw-semibold mt-1 mb-0"><i class="bi bi-calendar-x"></i> Deadline: <%= new Date(policy.deadline).toLocaleDateString() %></p>
              <% } %>
            </div>
            <div>
              <% if(policy.status==='completed' ){ %>
                <span class="badge bg-success px-3 py-2"><i class="bi bi-check-circle me-1"></i> Completed</span>
                <% } else if(policy.status==='pending_verification' ) { %>
                  <span class="badge bg-warning px-3 py-2"><i class="bi bi-hourglass-split me-1"></i> Under
                    Review</span>
                  <% } else { %>
                    <span class="badge bg-secondary px-3 py-2"><i class="bi bi-arrow-repeat me-1"></i> Action
                      Required</span>
                    <% } %>
            </div>
          </div>

          <div class="mb-5">
            <h6 class="text-muted text-uppercase small fw-semibold mb-2">Policy Description & Requirements</h6>
            <div class="p-3 rounded border" style="background: var(--surface-color);">
              <p class="mb-0">
                <%= policy.description %>
              </p>
            </div>
          </div>

          <% if(policy.status === 'rejected' && policy.rejection_reason) { %>
            <div class="alert alert-danger mb-4 d-flex align-items-start shadow-sm flex-column">
              <div class="d-flex w-100">
                <i class="bi bi-exclamation-triangle-fill fs-4 me-3 mt-1"></i>
                <div class="flex-grow-1">
                  <h5 class="alert-heading fw-semibold mb-1">Submission Rejected</h5>
                  <p class="mb-0 small"><%= policy.rejection_reason %></p>
                </div>
              </div>
            </div>
          <% } %>

          <div class="mb-5">
            <div class="d-flex align-items-center justify-content-between mb-3">
              <div class="d-flex align-items-center">
                <i class="bi bi-people-fill text-primary fs-5 me-2"></i>
                <h5 class="mb-0 fw-semibold">Assigned Students</h5>
              </div>
              <span class="badge bg-primary rounded-pill"><%= students.filter(s => s.acknowledged).length %> / <%= students.length %> Acknowledged</span>
            </div>

            <div class="card border">
              <ul class="list-group list-group-flush">
                <% students.forEach(s=> { %>
                  <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                    <div class="d-flex align-items-center">
                      <div
                        class="bg-light text-secondary rounded-circle d-flex align-items-center justify-content-center me-3"
                        style="width: 40px; height: 40px;">
                        <i class="bi bi-person fw-bold fs-5"></i>
                      </div>
                      <div>
                        <h6 class="mb-0 fw-medium">
                          <%= s.name %>
                        </h6>
                        <small class="text-muted">
                          <%= s.email %>
                        </small>
                      </div>
                    </div>
                    <div class="d-flex align-items-center">
                      <% if(s.acknowledged) { %>
                        <span class="badge bg-success me-3"><i class="bi bi-check-circle me-1"></i> Acknowledged</span>
                      <% } else { %>
                        <span class="badge bg-secondary me-3"><i class="bi bi-clock me-1"></i> Pending</span>
                      <% } %>
                      <a href="mailto:<%= s.email %>?subject=Regarding Green Policy: <%= policy.title %>"
                        class="btn btn-sm btn-outline-primary px-3">
                        <i class="bi bi-envelope me-1"></i> Contact
                      </a>
                    </div>
                  </li>
                  <% }) %>
                    <% if(students.length===0) { %>
                      <li class="list-group-item text-center py-4 text-muted fst-italic">
                        No students currently assigned to this policy.
                      </li>
                      <% } %>
              </ul>
            </div>
          </div>


          <% if(policy.status !=='completed' && policy.status !=='pending_verification' ) { %>
            <div>
              <div class="d-flex align-items-center mb-3">
                <i class="bi bi-cloud-arrow-up-fill text-success fs-5 me-2"></i>
                <h5 class="mb-0 fw-semibold">Upload Compliance Documentation</h5>
              </div>

              <div class="p-4 rounded border" style="background: var(--surface-color);">
                <form action="/staff/upload/<%= spid %>" method="POST" enctype="multipart/form-data">
                  <div class="mb-3">
                    <label class="form-label small text-muted">Select supporting document (.pdf, .jpg, .png)</label>
                    <input type="file" name="file" class="form-control" required>
                  </div>
                  <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success px-4">
                      <i class="bi bi-upload me-1"></i> Submit Documentation
                    </button>
                  </div>
                </form>
              </div>
            </div>
            <% } %>

        </div>

      </div>
    </div>

  </div>


  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>