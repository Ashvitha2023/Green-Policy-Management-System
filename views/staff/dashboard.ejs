<!DOCTYPE html>
<html>

<head>
  <title>Green Policy | Staff Dashboard</title>

  <meta name="viewport" content="width=device-width, initial-scale=1">
  <!-- Professional Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <!-- Formal UI CSS -->
  <link rel="stylesheet" href="/css/formal.css">

</head>

<body>

  <nav class="navbar px-4 py-2">
    <span class="navbar-brand mb-0 h1 d-flex align-items-center gap-2">
      <i class="bi bi-shield-lock"></i> Green Policy
      <span class="text-muted fs-6 ms-2 pb-1 border-start border-secondary ps-3">Staff Portal</span>
    </span>

    <a href="/logout" class="btn btn-outline-danger btn-sm px-3">
      <i class="bi bi-box-arrow-right"></i> Logout
    </a>
  </nav>

  <div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
      <h3 class="mb-0 text-primary fw-semibold">My Assigned Policies</h3>
      <div class="text-muted small">
        <i class="bi bi-person-workspace"></i> Staff Access
      </div>
    </div>


    <div class="row g-4">

      <% policies.forEach(p=> { %>

        <div class="col-md-6 col-lg-4">

          <div class="card formal-card h-100">

            <div class="card-body d-flex flex-column">

              <h5 class="card-title fw-semibold text-dark mb-3">
                <i class="bi bi-file-earmark-text text-primary me-2"></i>
                <%= p.title %>
              </h5>

              <div class="mb-4">
                <span class="text-muted small text-uppercase fw-medium d-block mb-1">Current Status</span>

                <% if(p.status==='completed' ){ %>
                  <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i> Completed</span>
                  <% } else if(p.status==='pending_verification' ) { %>
                    <span class="badge bg-warning"><i class="bi bi-hourglass-split me-1"></i> Under Review</span>
                    <% } else { %>
                      <span class="badge bg-secondary"><i class="bi bi-arrow-repeat me-1"></i> Action Required</span>
                      <% } %>
              </div>

              <a href="/staff/policy/<%= p.spid %>" class="btn btn-outline-primary w-100 mt-auto">
                View Policy Details
              </a>

            </div>

          </div>

        </div>

        <% }) %>

    </div>

  </div>


  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>